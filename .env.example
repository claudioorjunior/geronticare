# Database
DATABASE_URL="postgresql://user:password@localhost:5432/geronticare"

# Auth (Better-Auth)
AUTH_SECRET="your-secret-key-here-change-in-production"
AUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# S3-compatible storage (MinIO, Cloudflare R2, AWS S3, Backblaze B2)
S3_REGION="us-east-1"
S3_ENDPOINT=""              # e.g. http://localhost:9000 (MinIO) or https://xxx.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET="geronticare-anexos"
S3_PUBLIC_URL=""            # CDN ou domínio público para acessar anexos
